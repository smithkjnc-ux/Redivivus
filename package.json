        "title": "CHASSIS: Save to Vault"
      },
      {
        "command": "chassis.scanVaultCodebase",
        "title": "CHASSIS: Scan Codebase to Vault"
      },
      {
        "command": "chassis.buildFromVault",
        "title": "CHASSIS: Build from Vault"
      },
      {
        "command": "chassis.openVault",
        "title": "CHASSIS: Open Vault"
