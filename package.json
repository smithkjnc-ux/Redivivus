      },
      {
        "command": "chassis.toggleGitHubBackup",
        "title": "CHASSIS: Toggle GitHub Auto-Backup",
        "category": "CHASSIS"
      },
      {
        "command": "chassis.showSetupProgress",
        "title": "Show Setup Progress"
      },
      {
        "command": "chassis.resetSessionUsage",
        "title": "CHASSIS: Reset Session Usage"
      },
      {
        "command": "chassis.resetDayUsage",
        "title": "CHASSIS: Reset Day Usage"
      },
      {
        "command": "chassis.resetWeekUsage",
        "title": "CHASSIS: Reset Week Usage"
