    "configuration": {
      "title": "Redivivus",
      "properties": {
        "redivivus.apiBase": {
          "type": "string",
          "default": "",
          "description": "Override the Redivivus cloud API base URL (leave blank for production). Example: http://localhost:3001/api/v1"
        },
        "redivivus.modelStrategy": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "economy",
            "balanced",
            "quality"
          ],
          "enumDescriptions": [
            "Economy — cheapest viable model for the job. Lowest cost; small risk of bugs on tricky tasks. Never uses top-tier.",
            "Balanced (recommended) — pro-tier model for most builds; escalates to the top model only for genuinely hard/novel tasks. Best cost-to-quality.",
            "Quality — favors the strongest models; escalates to top-tier readily. Highest quality, highest cost."
          ],
          "markdownDescription": "How Redivivus picks the AI model for each build. The build's difficulty (weighted by novelty, not size) is combined with this preference to choose the supervisor tier. **Balanced** keeps most builds on a pro-tier model and only uses the top model (e.g. Opus) for genuinely hard work. The build result card shows why each model was chosen."
        },
        "redivivus.editorRuleFiles": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "cursor",
              "windsurf",
              "gemini",
              "cline",
              "copilot"
            ]
          },
          "markdownDescription": "Which AI-editor rule files to generate in new projects (CLAUDE.md, .cursorrules, .windsurfrules, GEMINI.md, .clinerules, copilot-instructions). Default is **none** — the canonical rules always live in `.redivivus/rules.md`. Enable only the editors you actually use. Run **Redivivus: Configure Editor Rule Files** for a checklist."
        },
        "redivivus.defaultAI": {
          "type": "string",
          "default": "gemini",
          "enum": [
            "gemini",
            "claude",
            "openai",
            "groq",
            "xai",
            "kimi"
          ],
          "enumDescriptions": [
            "Google Gemini (free tier available)",
            "Anthropic Claude (paid)",
            "OpenAI GPT-4o / GPT-4o Mini (paid)",
            "Groq — Llama 3 (free tier)",
            "xAI Grok (paid)",
            "Moonshot Kimi (paid)"
          ],
          "description": "Which AI provider to use for Redivivus operations"
        },
        "redivivus.projectsDirectory": {
          "type": "string",
          "default": "~/projects",
          "description": "Directory containing all Redivivus projects for project listing and switching"
        },
        "redivivus.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Google Gemini API key — free at aistudio.google.com (or set GEMINI_API_KEY env var)"
        },
        "redivivus.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic Claude API key — console.anthropic.com (or set ANTHROPIC_API_KEY env var)"
        },
        "redivivus.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for GPT-4o — platform.openai.com (or set OPENAI_API_KEY env var)"
        },
        "redivivus.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key — free Llama 3 at console.groq.com (or set GROQ_API_KEY env var)"
        },
        "redivivus.xaiApiKey": {
          "type": "string",
          "default": "",
          "description": "xAI Grok API key — console.x.ai (or set XAI_API_KEY env var)"
        },
        "redivivus.kimiApiKey": {
          "type": "string",
          "default": "",
          "description": "Moonshot Kimi API key — platform.moonshot.cn (or set MOONSHOT_API_KEY env var)"
        },
        "redivivus.guardianEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Guardian AI — when 2+ AI keys are configured, the higher-ranked AI silently reviews and corrects the worker AI's responses before they reach you. Disable to skip the review step."
        },
        "redivivus.startupBehavior": {
          "type": "string",
          "default": "launcher",
          "enum": [
            "launcher",
            "lastProject"
          ],
          "enumDescriptions": [
            "Show the Welcome launcher screen with Start New / Open Existing / Recent Projects options",
            "Automatically reopen the most recent Redivivus project (falls back to launcher if none exists)"
          ],
          "description": "What Redivivus should do when launched without a specific folder open"
        },
        "redivivus.disabledProviders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of AI provider IDs that are manually disabled by the user."
        },
        "redivivus.buildMode": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "auto",
            "guided"
          ],
          "enumDescriptions": [
            "Ask every time — a mode picker appears on first build in each session",
            "Auto: AI builds immediately with no questions. Blueprint, snapshots, and history still recorded.",
            "Guided: full project interview (5 W's + style + constraints) before building. Answers saved to blueprint."
          ],
          "description": "Default build mode. Auto skips all questions; Guided runs a structured interview before building. Leave blank to be asked each session."
        },
        "redivivus.personality": {
          "type": "string",
          "default": "plain",
          "enum": [
            "plain",
            "friendly",
            "scifi",
            "horror",
            "hillbilly",
            "pirate",
            "snarky",
            "butler",
            "trashy",
            "surfer",
            "hacker",
            "roast"
          ],
          "description": "Redivivus personality tone. Changes how Redivivus talks - technical accuracy never changes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./ && mkdir -p out/data && cp src/data/commands.json out/data/commands.json && node scripts/postcompile-deploy.js && node scripts/postcompile.js",
    "package": "npm run compile && vsce package --no-dependencies",
    "test:sanity": "npm run compile && node scripts/test-webview-sanity.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test",
    "posttest": "node scripts/quality-gates.js",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.70.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "nock": "^14.0.15",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
