      {
        "command": "chassis.explainSelection",
        "title": "CHASSIS: Explain Selection"
      },
      {
        "command": "chassis.improveSelection",
        "title": "CHASSIS: Improve Selection"
      },
      {
        "command": "chassis.viewTimeline",
