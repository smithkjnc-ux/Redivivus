      {
        "command": "chassis.showChatGettingStarted",
        "title": "CHASSIS: Show Getting Started"
      },
      {
        "command": "chassis.openSettings",
        "title": "CHASSIS: AI API Setup"
      },
      {
        "command": "chassis.apiSetup",
        "title": "CHASSIS: AI API Setup (alias)"
      },
      {
        "command": "chassis.injectTerminalError",
        "title": "CHASSIS: Fix Last Terminal Error"
      },
      {
        "command": "chassis.inspectElement",
        "title": "CHASSIS: Inspect UI Element - Find Source Code"
      },
      {
        "command": "chassis.vaultDedup",
        "title": "CHASSIS: Vault - Find and Remove Duplicates"
