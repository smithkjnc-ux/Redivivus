      {
        "command": "chassis.showMap",
        "title": "CHASSIS: Show Architecture Map 🗺"
      },
      {
        "command": "chassis.selfDiagnostic",
        "title": "CHASSIS: Run Self-Diagnostic",
        "category": "CHASSIS"
      },
      {
        "command": "chassis.showPipelineTrace",
        "title": "CHASSIS: Show Pipeline Trace",
        "category": "CHASSIS"
      }
    ],
    "viewsWelcome": [
      {
        "view": "chassisPanel",
        "contents": "Welcome to CHASSIS\n\n[Open CHASSIS Dashboard](command:chassis.wizard)\n\n[Initialize Project](command:chassis.init)",
        "when": "!chassis.initialized"
      },
      {
        "view": "chassisPanel",
        "contents": "[Open CHASSIS Dashboard](command:chassis.wizard)",
        "when": "chassis.initialized"
      }
    ],
    "keybindings": [
      {
        "command": "chassis.openChatPanel",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "chassis.wizard",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "chassis.buildFromVault",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "chassis.savePoint",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus || terminalFocus"
      },
      {
        "command": "chassis.injectTerminalError",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "terminalFocus || editorTextFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "chassis.init",
          "when": "!chassis.initialized"
        },
        {
          "command": "chassis.startSession",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.endSession",
          "when": "chassis.sessionActive"
        },
        {
          "command": "chassis.blueprint",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.progress",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.log",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.deadends",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.openBlueprint",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.wizard",
          "when": "chassis.initialized"
        },
        {
          "command": "chassis.buildFromVault",
          "when": "chassis.initialized"
        }
      ],
      "editor/context": [
        {
          "submenu": "chassis.editor",
          "group": "9_chassis@1"
        }
      ],
      "explorer/context": [
        {
          "submenu": "chassis.explorer",
          "group": "9_chassis@1"
        }
      ],
      "chassis.editor": [
        {
          "command": "chassis.reviewFile",
          "group": "chassis@1"
        },
        {
          "command": "chassis.cleanUpFile",
          "group": "chassis@2"
        },
        {
          "command": "chassis.checkFileHealth",
          "group": "chassis@3"
        },
        {
          "command": "chassis.explainSelection",
          "group": "chassis@4",
          "when": "editorHasSelection"
        },
        {
          "command": "chassis.improveSelection",
          "group": "chassis@5",
          "when": "editorHasSelection"
        },
        {
          "command": "chassis.saveSelectionToVault",
          "group": "chassis@6",
          "when": "editorHasSelection"
        },
        {
          "command": "chassis.saveToVault",
          "group": "chassis@7"
        }
      ],
      "chassis.explorer": [
        {
          "command": "chassis.reviewFile",
          "group": "chassis@1"
        },
        {
          "command": "chassis.cleanUpFile",
          "group": "chassis@2"
        },
        {
          "command": "chassis.checkFileHealth",
          "group": "chassis@3"
        },
        {
          "command": "chassis.saveToVault",
          "group": "chassis@4"
        }
      ]
    },
    "submenus": [
      {
        "id": "chassis.editor",
        "label": "CHASSIS"
      },
      {
        "id": "chassis.explorer",
        "label": "CHASSIS"
      }
    ],
    "configuration": {
      "title": "CHASSIS",
      "properties": {
        "chassis.defaultAI": {
          "type": "string",
          "default": "gemini",
          "enum": [
            "gemini",
            "claude",
            "openai",
            "groq",
            "xai",
            "kimi"
          ],
          "enumDescriptions": [
            "Google Gemini (free tier available)",
            "Anthropic Claude (paid)",
            "OpenAI GPT-4o / GPT-4o Mini (paid)",
            "Groq \u2014 Llama 3 (free tier)",
            "xAI Grok (paid)",
            "Moonshot Kimi (paid)"
          ],
          "description": "Which AI provider to use for CHASSIS operations"
        },
        "chassis.projectsDirectory": {
          "type": "string",
          "default": "~/projects",
          "description": "Directory containing all CHASSIS projects for project listing and switching"
        },
        "chassis.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Google Gemini API key \u2014 free at aistudio.google.com (or set GEMINI_API_KEY env var)"
        },
        "chassis.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic Claude API key \u2014 console.anthropic.com (or set ANTHROPIC_API_KEY env var)"
        },
        "chassis.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for GPT-4o \u2014 platform.openai.com (or set OPENAI_API_KEY env var)"
        },
        "chassis.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key \u2014 free Llama 3 at console.groq.com (or set GROQ_API_KEY env var)"
        },
        "chassis.xaiApiKey": {
          "type": "string",
          "default": "",
          "description": "xAI Grok API key — console.x.ai (or set XAI_API_KEY env var)"
        },
        "chassis.kimiApiKey": {
          "type": "string",
          "default": "",
          "description": "Moonshot Kimi API key — platform.moonshot.cn (or set MOONSHOT_API_KEY env var)"
        },
        "chassis.guardianEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Guardian AI — when 2+ AI keys are configured, the higher-ranked AI silently reviews and corrects the worker AI's responses before they reach you. Disable to skip the review step."
        },
        "chassis.startupBehavior": {
          "type": "string",
          "default": "launcher",
          "enum": [
            "launcher",
            "lastProject"
          ],
          "enumDescriptions": [
            "Show the Welcome launcher screen with Start New / Open Existing / Recent Projects options",
            "Automatically reopen the most recent CHASSIS project (falls back to launcher if none exists)"
          ],
          "description": "What CHASSIS should do when launched without a specific folder open"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./ && mkdir -p out/data && cp src/data/commands.json out/data/commands.json && node scripts/postcompile.js",
    "test:sanity": "npm run compile && node scripts/test-webview-sanity.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.70.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
