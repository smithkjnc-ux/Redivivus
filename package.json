{
  "name": "chassis",
  "displayName": "CHASSIS",
  "description": "AI-agnostic coding protocol for VS Code \u2014 the frame everything bolts to",
  "version": "0.3.6",
  "publisher": "papajoe",
  "icon": "resources/chassis-icon-128.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
